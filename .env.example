# PiHerder environment variables
# Copy to .env and fill in real values:
#   cp .env.example .env

# REQUIRED — Fernet key used to encrypt SSH private keys (and optional SSH passwords) at rest.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PIHERDER_MASTER_KEY=

# REQUIRED — JWT signing secret for login sessions. Use a long random string in production.
SECRET_KEY=change-me-in-prod

# Optional — host timezone passed into the web container (e.g. Africa/Johannesburg)
# TZ=Etc/UTC

# Optional — legacy-style webhook notifications (replicates bash script alerts)
# WEBHOOK_URL=
# WEBHOOK_NUMBER=
# WEBHOOK_RECIPIENTS=["+1..."]

# Public hostname for Caddy HTTPS site block (must match TLS cert SANs)
# Compose passes this into the caddy service. Example:
# PIHERDER_HOSTNAME=piherder.hacknow.com

# Canonical browser origin (include :8443 if you keep compose host mapping 8443→443)
# Used by the app for status UI / absolute links. Example:
# PIHERDER_PUBLIC_URL=https://piherder.hacknow.com:8443

# Trusted TLS for Caddy: place files in ./certs/ (see certs/README.md)
#   fullchain.pem
#   privkey.pem
# Local without certs: mount Caddyfile.dev instead (self-signed; push unreliable).

# Web Push — optional. By default VAPID keys are auto-generated at web startup
# and stored encrypted in Postgres (stable for the life of the install).
# Set these only to pin/override keys (e.g. restore across DB wipe with same keys):
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CONTACT=mailto:admin@example.com

# Optional — cron schedule for PiHerder self-backups (config + encrypted keys)
# HERDER_BACKUP_SCHEDULE=0 3 * * *

# Optional — link to co-located Pi-hole admin UI (shown on dashboard)
# PIHOLE_URL=http://pi.hole/admin/

# Host path mounted as /backups in web + celery (rsync destinations).
# Default in compose is ./backups. Example: PIHERDER_BACKUP_HOST_PATH=/home/bjorn/backup
# PIHERDER_BACKUP_HOST_PATH=./backups

# Prometheus scrape (GET /metrics). If set, require Authorization: Bearer <token>
# (or X-Metrics-Token). Leave empty only on private networks.
# METRICS_TOKEN=
# METRICS_BACKUP_STALE_HOURS=36

# Notes:
# - First registered user becomes the admin; further open registration is locked.
# - Optional TOTP 2FA is configured in-app under Account (no extra env vars).
# - Avatars and app data use the compose-mounted data volume when present.
# - Fleet OS/container update-check schedules are configured in the UI (Settings / per server).
# - Android PWA install + Web Push need trusted HTTPS on PIHERDER_HOSTNAME (not tls internal).
# - Automation API tokens (ph_…) are created in-app under Settings → API tokens (not env).