# =============================================================================
# PiHerder — sample environment
# =============================================================================
# Copy and edit:
#   cp .env.example .env
#
# Compose reads this file for ${VAR} interpolation and (via docker-compose.yml)
# injects matching keys into web / celery / caddy. Lines that stay commented
# use app or compose defaults.
#
# Generate secrets:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   openssl rand -hex 32
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Fernet key — encrypts SSH private keys (and optional SSH passwords) at rest.
# Must be a url-safe base64-encoded 32-byte key (Fernet.generate_key()).
PIHERDER_MASTER_KEY=

# JWT signing secret for browser login sessions. Use a long random string in production.
SECRET_KEY=change-me-in-prod

# -----------------------------------------------------------------------------
# Public URL / TLS (Caddy)
# -----------------------------------------------------------------------------

# Hostname for the Caddy HTTPS site block — must match cert SANs.
# PIHERDER_HOSTNAME=piherder.example.com

# Canonical browser origin (include :8443 if you keep compose host mapping 8443→443).
# Used for status UI, absolute links, Web Push.
# PIHERDER_PUBLIC_URL=https://piherder.example.com:8443

# Trusted TLS: place fullchain.pem + privkey.pem in ./certs/ (see certs/README.md).
# Local without certs: mount Caddyfile.dev instead of Caddyfile (self-signed; push unreliable).

# Optional container timezone (e.g. Africa/Johannesburg). Not required by the app.
# TZ=Etc/UTC

# -----------------------------------------------------------------------------
# Host paths (compose volume mounts — host side)
# -----------------------------------------------------------------------------

# Host directory mounted as /backups in web + celery (rsync destinations).
# Default: ./backups  ·  Example secondary drive: /home/bjorn/backup
# PIHERDER_BACKUP_HOST_PATH=./backups

# Other mounts are fixed in docker-compose.yml (override there if needed):
#   ./piherder_backups  → /herder_backups   (PiHerder self-backup archives)
#   ./piherder_data     → /data            (avatars / app data)
#   ./certs             → /certs (Caddy, ro)

# -----------------------------------------------------------------------------
# Database (defaults match the compose `db` service)
# -----------------------------------------------------------------------------

# App connection string. Compose default points at service name `db`.
# Only change if you use an external Postgres (and set credentials accordingly).
# DATABASE_URL=postgresql://piherder:piherder@db:5432/piherder

# Compose `db` service uses fixed POSTGRES_* in docker-compose.yml
# (user/password/db = piherder). Edit compose if you change them — keep DATABASE_URL in sync.

# -----------------------------------------------------------------------------
# Redis / Celery
# -----------------------------------------------------------------------------

# Broker + result backend (compose default: redis service).
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# Optional alternate Redis URL used only as a stack-health fallback probe.
# REDIS_URL=redis://redis:6379/0

# Parallel backup workers (prefork processes in the celery-worker container).
# Default 2. Raise for larger fleets (CPU/RAM + SSH budget). Per-server mutex
# still serializes two backups to the *same* host.
# CELERY_CONCURRENCY=2

# TTL (seconds) for the Redis per-server backup lock. Default 7200 (matches
# Celery task_time_limit). Covers long rsync; expires after worker crash.
# PIHERDER_SERVER_LOCK_TTL=7200

# -----------------------------------------------------------------------------
# Paths inside the container (app Settings — rarely change under compose)
# -----------------------------------------------------------------------------

# BACKUP_ROOT=/backups
# HERDER_BACKUP_ROOT=/herder_backups
# DATA_ROOT=/data
# DEFAULT_DOCKER_BASE=~/docker
# AVATAR_MAX_BYTES=2097152

# -----------------------------------------------------------------------------
# Auth / sessions
# -----------------------------------------------------------------------------

# JWT algorithm (default HS256).
# ALGORITHM=HS256

# Session lifetime in minutes (default 10080 = 7 days).
# ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 2FA “trust this device” cookie max age in days (default 30).
# TRUSTED_DEVICE_DAYS=30

# When false (default), public /register is open only until the first admin
# registers, then blocked. There is no default admin@example.com user.
# Set true only for controlled multi-user signup (first user is still admin).
# ALLOW_OPEN_REGISTRATION=false

# Auth cookies: empty = auto Secure when PIHERDER_PUBLIC_URL is https://…
# COOKIE_SECURE=true

# -----------------------------------------------------------------------------
# Webhooks (optional — legacy script-style alerts on new notifications / jobs)
# -----------------------------------------------------------------------------

# WEBHOOK_URL=https://your-n8n-or-bridge.example/webhook/...
# WEBHOOK_NUMBER=+15551234567
# WEBHOOK_RECIPIENTS=["+15551234567"]

# -----------------------------------------------------------------------------
# Web Push (VAPID) — optional override
# -----------------------------------------------------------------------------
# By default keys are auto-generated at web startup and stored encrypted in
# Postgres (stable for the life of the install). Set these only to pin/override
# (e.g. restore across DB wipe with the same keys):
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_CONTACT=mailto:admin@example.com

# -----------------------------------------------------------------------------
# PiHerder self-backup schedule (optional env seed)
# -----------------------------------------------------------------------------
# Cron for herder config backups. Can also be set in Settings UI (DB wins after save).
# HERDER_BACKUP_SCHEDULE=0 3 * * *

# -----------------------------------------------------------------------------
# Dashboard extras
# -----------------------------------------------------------------------------

# Link to co-located Pi-hole admin UI (dashboard). Empty/unset hides or uses default.
# PIHOLE_URL=http://pi.hole/admin/

# -----------------------------------------------------------------------------
# Prometheus metrics (GET /metrics)
# -----------------------------------------------------------------------------

# If set, require Authorization: Bearer <token> (or X-Metrics-Token).
# Leave empty only on a private scrape network.
# Bearer for GET /metrics — set in production (empty = open on app port)
# METRICS_TOKEN=
# Hours without a successful backup before a server is “stale” in metrics.
# METRICS_BACKUP_STALE_HOURS=36

# -----------------------------------------------------------------------------
# CORS (rare — browser clients on another origin calling /api/v1)
# -----------------------------------------------------------------------------
# Leave empty for n8n/HA/scripts (server-side; CORS does not apply).
# Exact origins only, comma-separated. Never *. Backend still requires Bearer +
# scopes + optional IP allowlist on the token.
# CORS_ORIGINS=https://n8n.example.com,https://homeassistant.local:8123

# =============================================================================
# Notes (not env vars)
# =============================================================================
# - First registered user becomes admin; further open registration stays locked
#   unless ALLOW_OPEN_REGISTRATION=true.
# - TOTP 2FA, fleet tokens (ph_…), fleet schedules, and most ops settings are
#   configured in the UI / Postgres — not here.
# - Android PWA + Web Push need trusted HTTPS on PIHERDER_HOSTNAME (not tls internal).
# - Multi-worker: see CELERY_CONCURRENCY + docs/ADMIN.md § Multi-worker Celery.
# - Full ops guide: docs/ADMIN.md · Security: SECURITY.md
# =============================================================================
