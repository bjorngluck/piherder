# Vendored frontend assets — always re-download via scripts/vendor_cdns.sh
# so a bad/stale local file (e.g. Pi-hole block page) never ships.
app/static/tailwind.js
app/static/htmx.min.js
app/static/alpine.min.js

# Local runtime / secrets — never ship into public Hub images
.env*
*.pem
id_rsa*
tmp_ssh_key_*
certs/
piherder_backups/
piherder_data/
backups/

# VCS / tooling / caches
.git/
.github/
.venv*/
.pytest_cache/
__pycache__/
*.pyc
*.pyo
*.egg-info/
*.log

# Docs build output and sources (not needed at runtime)
site/
wiki/
docs/
mkdocs.yml
requirements-docs.txt

# Dev-only / large lock sources not used by Dockerfile
uv.lock
.pytest_cache/

# Local IDE / OS noise
.idea/
.vscode/
*.swp
.DS_Store
