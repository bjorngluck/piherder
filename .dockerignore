# We ignore the vendored JS files from the build context.
# This ensures the build always uses fresh copies produced by scripts/vendor_cdns.sh
# (and prevents shipping a bad/stale file, e.g. from Pi-hole).
#
# The build will fail hard if the vendoring step cannot produce a valid tailwind.js.
#
# If you want to do a fully offline build, you can:
#   1. Manually place valid files in app/static/ before building, AND
#   2. Temporarily comment out the lines below, or use a multi-stage COPY.
app/static/tailwind.js
app/static/htmx.min.js
app/static/alpine.min.js

# Other common ignores
__pycache__/
*.pyc
.env*
*.log
backups/
tmp_ssh_key_*
*.pem
id_rsa*
