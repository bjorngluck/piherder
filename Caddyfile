# PiHerder Caddyfile — production-oriented
# Host ports (compose): 8888→80 (HTTP), 8443→443 (HTTPS)
# Trusted TLS: place fullchain.pem + privkey.pem in ./certs (mounted at /certs)
# Hostname: set PIHERDER_HOSTNAME in .env (e.g. piherder.hacknow.com)
#
# Local dev without certs: use Caddyfile.dev (see docs/ADMIN.md)

{
	admin off
	# Non-standard host ports; do not auto-redirect HTTP→HTTPS on 443
	auto_https off
}

# HTTP — host :8888
:80 {
	# When Host matches public hostname, send browsers to HTTPS on host port 8443
	@public host {$PIHERDER_HOSTNAME}
	redir @public https://{$PIHERDER_HOSTNAME}:8443{uri} 308

	# Pass real client IP for API token CIDR allowlists (backend uses these headers).
	# Use remote_host (IP only) — not {remote} which can include :port.
	# Overwrite headers (do not append client-supplied XFF) to avoid spoofing.
	reverse_proxy web:8000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}
	encode gzip
}

# HTTPS — host :8443 — volume-mounted trusted certificate
{$PIHERDER_HOSTNAME}:443 {
	tls /certs/fullchain.pem /certs/privkey.pem

	reverse_proxy web:8000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto https
		header_up X-Forwarded-Host {host}
	}

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer-when-downgrade"
	}
	encode gzip
}
